generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  superadmin
  admin
  editor
  publisher
  poet
  reader
}

enum UserStatus {
  active
  inactive
  suspended
  pending_verification
}

enum ProfileVisibility {
  public
  private
}

enum ContactMessageStatus {
  unread
  read
  archived
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique @db.VarChar(255)
  username        String      @unique @db.VarChar(50)
  displayName     String?     @map("display_name") @db.VarChar(100)
  passwordHash    String?     @map("password_hash") @db.VarChar(255)
  avatarUrl       String?     @map("avatar_url") @db.LongText
  bio             String?     @db.Text
  languagePrefs   Json?       @map("language_prefs") // Used instead of arrays in MySQL
  role            UserRole    @default(reader)
  status          UserStatus  @default(active)
  isVerified      Boolean?    @default(false) @map("is_verified")
  emailVerified   Boolean?    @default(false) @map("email_verified")
  oauthProvider   String?     @map("oauth_provider") @db.VarChar(50)
  oauthId         String?     @map("oauth_id") @db.VarChar(255)
  tenantId        String?     @map("tenant_id")
  tenant          Tenant?     @relation(fields: [tenantId], references: [id])
  createdAt       DateTime?   @default(now()) @map("created_at")
  updatedAt       DateTime?   @default(now()) @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")
  lastLoginAt     DateTime?   @map("last_login_at")
  metadata        Json?       

  contents        Content[]
  collections     Collection[]
  comments        Comment[]
  contentLikes    ContentLike[]
  auditLogs       AuditLog[]
  bookmarks       Bookmark[]

  followers       Follow[]    @relation("UserFollowers")
  following       Follow[]    @relation("UserFollowing")

  @@map("users")
}

enum SubscriptionPlan {
  free
  basic
  premium
  enterprise
}

model Tenant {
  id            String             @id @default(uuid())
  name          String             @db.VarChar(100)
  slug          String             @unique @db.VarChar(50)
  domain        String?            @db.VarChar(255)
  logoUrl       String?            @map("logo_url")
  plan          SubscriptionPlan?  @default(free)
  settings      Json?              
  isActive      Boolean?           @default(true) @map("is_active")
  createdAt     DateTime?          @default(now()) @map("created_at")
  updatedAt     DateTime?          @default(now()) @map("updated_at")
  
  users               User[]
  contents            Content[]
  collections         Collection[]
  rolePermissions     RolePermission[]
  auditLogs           AuditLog[]

  @@map("tenants")
}

enum ContentType {
  poem
  ghazal
  nazm
  sher
  qita
  story
  essay
  translation
  article
}

enum ContentStatus {
  draft
  review
  approved
  published
  rejected
  archived
}

model Content {
  id              String         @id @default(uuid())
  title           String         @db.VarChar(500)
  slug            String         @unique @db.VarChar(500)
  body            String?        @db.Text
  bodyUrdu        String?        @map("body_urdu") @db.Text
  bodyHindi       String?        @map("body_hindi") @db.Text
  excerpt         String?        @db.Text
  contentType     ContentType    @map("content_type")
  language        String         @default("ur") @db.VarChar(10)
  authorId        String         @map("author_id")
  author          User           @relation(fields: [authorId], references: [id])
  tenantId        String         @map("tenant_id")
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  collectionId    String?        @map("collection_id")
  collection      Collection?    @relation(fields: [collectionId], references: [id])
  coverImageUrl   String?        @map("cover_image_url")
  audioUrl        String?        @map("audio_url")
  videoUrl        String?        @map("video_url")
  status          ContentStatus  @default(draft)
  isPremium       Boolean?       @default(false) @map("is_premium")
  isFeatured      Boolean?       @default(false) @map("is_featured")
  viewCount       BigInt?        @default(0) @map("view_count")
  likeCount       BigInt?        @default(0) @map("like_count")
  bookmarkCount   BigInt?        @default(0) @map("bookmark_count")
  tags            Json?          // Array alternative for MySQL
  metadata        Json?          
  publishedAt     DateTime?      @map("published_at")
  createdAt       DateTime?      @default(now()) @map("created_at")
  updatedAt       DateTime?      @default(now()) @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  comments        Comment[]
  likes           ContentLike[]
  bookmarks       Bookmark[]

  @@map("content")
}

model ContentLike {
  userId      String    @map("user_id")
  contentId   String    @map("content_id")
  createdAt   DateTime? @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id])
  content     Content   @relation(fields: [contentId], references: [id])

  @@id([userId, contentId])
  @@map("content_likes")
}

model Collection {
  id            String      @id @default(uuid())
  title         String      @db.VarChar(300)
  slug          String      @unique @db.VarChar(300)
  description   String?     @db.Text
  coverUrl      String?     @map("cover_url")
  curatorId     String      @map("curator_id")
  curator       User        @relation(fields: [curatorId], references: [id])
  tenantId      String      @map("tenant_id")
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  isPublic      Boolean?    @default(true) @map("is_public")
  isFeatured    Boolean?    @default(false) @map("is_featured")
  contentCount  Int?        @default(0) @map("content_count")
  createdAt     DateTime?   @default(now()) @map("created_at")
  updatedAt     DateTime?   @default(now()) @map("updated_at")

  contents      Content[]

  @@map("collections")
}

enum CommentStatus {
  visible
  hidden
  flagged
  deleted
}

model Comment {
  id          String         @id @default(uuid())
  contentId   String         @map("content_id")
  content     Content        @relation(fields: [contentId], references: [id])
  userId      String         @map("user_id")
  user        User           @relation(fields: [userId], references: [id])
  parentId    String?        @map("parent_id")
  parent      Comment?       @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[]      @relation("CommentReplies")
  body        String         @db.Text
  status      CommentStatus? @default(visible)
  likeCount   Int?           @default(0) @map("like_count")
  createdAt   DateTime?      @default(now()) @map("created_at")
  updatedAt   DateTime?      @default(now()) @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  @@map("comments")
}

model Follow {
  followerId  String    @map("follower_id")
  followingId String    @map("following_id")
  createdAt   DateTime? @default(now()) @map("created_at")

  follower    User      @relation("UserFollowing", fields: [followerId], references: [id])
  following   User      @relation("UserFollowers", fields: [followingId], references: [id])

  @@id([followerId, followingId])
  @@map("follows")
}

model Bookmark {
  userId      String    @map("user_id")
  contentId   String    @map("content_id")
  createdAt   DateTime? @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id])
  content     Content   @relation(fields: [contentId], references: [id])

  @@id([userId, contentId])
  @@map("bookmarks")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  description String?
  module      String?  @db.VarChar(50)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserProfile {
  userId      String    @id @map("user_id") @db.VarChar(64)
  name        String    @db.VarChar(120)
  role        String    @db.VarChar(80)
  visibility  ProfileVisibility @default(public)
  city        String    @db.VarChar(100)
  state       String    @db.VarChar(100)
  country     String    @db.VarChar(100)
  timezone    String    @db.VarChar(80)
  bio         String    @db.Text
  avatarUrl   String?   @map("avatar_url") @db.LongText
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model ContactMessage {
  id        String                @id @default(uuid())
  name      String                @db.VarChar(120)
  email     String                @db.VarChar(255)
  category  String                @db.VarChar(100)
  message   String                @db.Text
  status    ContactMessageStatus  @default(unread)
  readAt    DateTime?             @map("read_at")
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  @@map("contact_messages")
}

model RolePermission {
  role          UserRole
  permissionId  String      @map("permission_id")
  tenantId      String?     @map("tenant_id")

  permission    Permission  @relation(fields: [permissionId], references: [id])
  tenant        Tenant?     @relation(fields: [tenantId], references: [id])

  @@id([role, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  tenantId    String?   @map("tenant_id")
  action      String    @db.VarChar(100)
  resource    String?   @db.VarChar(100)
  resourceId  String?   @map("resource_id")
  oldData     Json?     @map("old_data")
  newData     Json?     @map("new_data")
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent")
  createdAt   DateTime? @default(now()) @map("created_at")

  user        User?     @relation(fields: [userId], references: [id])
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])

  @@map("audit_logs")
}
